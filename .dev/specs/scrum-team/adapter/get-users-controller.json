{
  "useCase": "GetUsersController",
  "behavior": "Get all users in the system.",
  "spec": {
    "basePath": "/v1/api/users",
    "endpoints": [
      {
        "method": "GET",
        "path": "",
        "summary": "Get all users",
        "useCase": "GetUsersUseCase",
        "mapping": {
          "input": { "type": "none" },
          "output": { "mode": "sync-200", "dto": "UserListResponse" }
        },
        "produces": ["application/json"],
        "responses": {
          "200": { "body": "UserListResponse" },
          "401": { "body": "ApiError" },
          "403": { "body": "ApiError" },
          "500": { "body": "ApiError" }
        },
        "headers": {
          "request": [],
          "response": ["traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "InternalError", "http": 500, "code": "INTERNAL_ERROR" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "UserListResponse",
        "fields": [
          { "name": "users", "type": "List<UserDto>" },
          { "name": "totalCount", "type": "int" }
        ]
      },
      {
        "name": "UserDto",
        "fields": [
          { "name": "id", "type": "string" },
          { "name": "name", "type": "string" },
          { "name": "email", "type": "string" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "caching": { "enabled": true, "ttlSeconds": 60 },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics": true }
  }
}